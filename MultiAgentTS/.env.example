# API Configuration
# Replace with your actual API key
API_KEY=your-api-key-here

# Base URL for the API
BASE_URL=https://api.example.com/v1

# Model Configuration
# Code Generator Model
CODE_GENERATOR_MODEL=claude-sonnet-4-1-thinking

# Analysis Model
ANALYSIS_MODEL=gpt-4o

# Reflector Model
REFLECTOR_MODEL=claude-sonnet-4-1-thinking

# Expert Model (optional, defaults to CODE_GENERATOR_MODEL)
EXPERT_MODEL=deepseek-chat

# Path Configuration
TIME_BLENDER_PATH=./time_blender

# Log and Report Paths
LOG_FILE_PATH=process_log.txt
DATA_REPORT_PATH=data_report.txt

