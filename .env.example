# LongTS-Industrial 环境变量示例
# 复制为 .env 并填入你自己的 Key（.env 已被 .gitignore 忽略，不会进仓库）

# DashScope（阿里云）：评测的 Judge(qwen-plus) 与 Embedding(text-embedding-v3)，
# 以及通过 DashScope 调用的 VLM 推理
DASHSCOPE_API_KEY=

# VLM 推理后端（本地 vLLM 设为 EMPTY；走 DashScope 时可不设，默认复用上面的 Key）
VLM_API_KEY=
VLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 独立第三方 Judge（如 GPT 系列，用于一致性交叉验证，可选）
JUDGE_API_KEY=
JUDGE_BASE_URL=
